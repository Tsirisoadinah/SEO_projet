RewriteEngine On

# Ancienne URL par ID : /frontoffice/article/1
RewriteRule ^article/([0-9]+)$ article.php?id=$1 [L,QSA]

# URL propre en frontoffice : /frontoffice/titre-de-l-article.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)\.html$ article.php?slug=$1 [L,QSA]